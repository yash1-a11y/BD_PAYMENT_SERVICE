# Required — the app will not start without these set.
# Never reuse these example values outside local dev.
DATABASE_URL=postgresql+psycopg://bd_payment:bd_payment@localhost:5432/bd_payment_service
JWT_SECRET=replace-with-a-long-random-secret-per-environment
JWT_EXPIRE_MINUTES=1440
PACKAGE_SYSTEM_BASE_URL=https://search.adda247.com/v13/packages/info
PACKAGE_SYSTEM_SRC=aweb
ALLOWED_ORIGINS=["http://localhost:3000"]

# Transfi credentials — obtain from the Transfi Merchant Dashboard.
# TRANSFI_PAYMENT_LINK_ID is a one-time Checkout Widget config value;
# reuse the same one for every payment, never create a new widget per order.
TRANSFI_BASE_URL=https://checkout-server.transfi.com
TRANSFI_PUBLIC_KEY=replace-with-real-transfi-public-key
TRANSFI_SECRET_KEY=replace-with-real-transfi-secret-key
TRANSFI_PAYMENT_LINK_ID=replace-with-real-transfi-payment-link-id
TRANSFI_SUCCESS_URL=https://your-domain.example/skill-bangla
TRANSFI_FAILURE_URL=https://your-domain.example/skill-bangla
# Dedicated webhook signing secret — different from TRANSFI_SECRET_KEY,
# configured separately in the Transfi dashboard for webhook delivery.
TRANSFI_WEBHOOK_SECRET=replace-with-real-transfi-webhook-secret

# Optional — both have safe defaults, existing .env files don't need these.
APP_ENV=production
LOG_LEVEL=INFO
